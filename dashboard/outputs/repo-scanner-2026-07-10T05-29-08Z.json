{
  "root": "card_main",
  "state": {},
  "elements": {
    "card_main": {
      "type": "Card",
      "props": {
        "title": "repo-scanner"
      },
      "children": [
        "content_stack"
      ]
    },
    "content_stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "lg"
      },
      "children": [
        "summary_section",
        "separator1",
        "finding_section"
      ]
    },
    "summary_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "heading_summary",
        "stats_grid"
      ]
    },
    "heading_summary": {
      "type": "Heading",
      "props": {
        "text": "Catalog Summary",
        "level": "h2"
      },
      "children": []
    },
    "stats_grid": {
      "type": "Grid",
      "props": {
        "columns": 3,
        "gap": "md"
      },
      "children": [
        "stat_total",
        "stat_breakdown",
        "stat_forks"
      ]
    },
    "stat_total": {
      "type": "Stat",
      "props": {
        "label": "Repositories Cataloged",
        "value": "32"
      },
      "children": []
    },
    "stat_breakdown": {
      "type": "Stat",
      "props": {
        "label": "Status Breakdown",
        "value": "30/1/1"
      },
      "children": []
    },
    "stat_forks": {
      "type": "Stat",
      "props": {
        "label": "Forks",
        "value": "13"
      },
      "children": []
    },
    "separator1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
    },
    "finding_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "heading_finding",
        "repo_storylink",
        "action_alert"
      ]
    },
    "heading_finding": {
      "type": "Heading",
      "props": {
        "text": "Top Finding",
        "level": "h2"
      },
      "children": []
    },
    "repo_storylink": {
      "type": "StoryLink",
      "props": {
        "title": "aaronjmars/awesome-ai-agents-slava",
        "href": "https://github.com/aaronjmars/awesome-ai-agents-slava",
        "source": "GitHub"
      },
      "children": []
    },
    "action_alert": {
      "type": "Alert",
      "props": {
        "title": "MISSING_CI",
        "message": "Add lychee link-check workflow for 300+ curated agentic AI links",
        "type": "warning"
