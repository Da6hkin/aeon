{
  "root": "card",
  "state": {},
  "elements": {
    "card": {
      "type": "Card",
      "props": {
        "title": "heartbeat"
      },
      "children": [
        "stack"
      ]
    },
    "stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "failed-alert",
        "stale-alert",
        "status-section"
      ]
    },
    "failed-alert": {
      "type": "Alert",
      "props": {
        "title": "🔴 FAILED: chain:overnight-research",
        "message": "Failed 2026-05-20 16:50Z (~4h ago)",
        "type": "error"
      }
    },
    "stale-alert": {
      "type": "Alert",
      "props": {
        "title": "🔵 STALE: startup-idea",
        "message": "Runs every 6h, last succeeded 2026-05-15 — 5 days stale. Likely tied to overnight-research chain failures.",
        "type": "warning"
      }
    },
    "status-section": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "sm"
      },
      "children": [
        "status-label",
        "status-badge"
      ]
    },
    "status-label": {
      "type": "Text",
      "props": {
        "text": "Status page:",
        "variant": "muted"
      }
    },
    "status-badge": {
      "type": "Badge",
      "props": {
        "text": "DEGRADED",
        "variant": "destructive"
      }
    }
  }
}
