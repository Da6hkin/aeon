        "stat-total",
        "stat-distribution",
        "stat-forks"
      ]
    },
    "stat-total": {
      "type": "Stat",
      "props": {
        "label": "Total Repos",
        "value": "32"
      },
      "children": []
    },
    "stat-distribution": {
      "type": "Stat",
      "props": {
        "label": "Distribution",
        "value": "30/1/1"
      },
      "children": []
    },
    "stat-forks": {
      "type": "Stat",
      "props": {
        "label": "Forks",
        "value": "13"
      },
      "children": []
    },
    "separator-1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
    },
    "stack-findings": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
