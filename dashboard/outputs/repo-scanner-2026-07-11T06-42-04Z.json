{
  "root": "card-main",
  "state": {},
  "elements": {
    "card-main": {
      "type": "Card",
      "props": {
        "title": "repo-scanner",
        "description": "Cataloged 32 repos · 13 forks"
      },
      "children": [
        "stack-stats",
        "separator-1",
        "stack-findings"
      ]
    },
    "stack-stats": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "grid-metrics"
      ]
    },
    "grid-metrics": {
      "type": "Grid",
      "props": {
